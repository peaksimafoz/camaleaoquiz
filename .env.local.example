# Copie este arquivo para .env.local e preencha com as chaves do seu projeto Supabase.
# (Supabase Dashboard → Project Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # "anon public" key
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # "service_role" key (SECRETA — nunca commitar)

# E-mail automático via Gmail (opcional). Conta dedicada + App Password (16 letras).
# Necessário para o envio do resultado + e-book quando o quiz tem e-mail ativado.
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx    # senha de app (SECRETA — nunca commitar)
